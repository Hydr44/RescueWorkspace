# RescueManager - Environment Variables Template
# Copy this file to .env.local and fill in your values

# Environment
NODE_ENV=development
NEXT_PUBLIC_ENV=development

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=rescuemanager-production

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (Brevo/SendGrid/etc)
EMAIL_FROM=noreply@rescuemanager.eu
EMAIL_API_KEY=your-email-api-key

# VPS Services
VPS_API_BASE_URL=https://api.rescuemanager.eu
VPS_ASSIST_BASE=assist.rescuemanager.eu
VPS_RENTRI_BASE=rentri-test.rescuemanager.eu

# SDI
SDI_ID_NODO=02166430856
SDI_ID_NODO_CF=SCZMNL05L21D960T

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
SENTRY_AUTH_TOKEN=your-sentry-token
