# .env.example
# Configurazione per integrazione RVFU reale

# === CREDENZIALI ACI/MIT ===
# Client ID e Secret forniti da ACI per l'integrazione
VITE_RVFU_CLIENT_ID=your_client_id_here
VITE_RVFU_CLIENT_SECRET=your_client_secret_here

# URL di redirect per OAuth2 (deve essere registrato con ACI)
VITE_RVFU_REDIRECT_URI=http://localhost:8080/auth/callback

# === AMBIENTE FORMAZIONE ===
# Credenziali per ambiente di test/formazione
VITE_RVFU_FORMATION_USERNAME=your_formation_username
VITE_RVFU_FORMATION_PASSWORD=your_formation_password

# === AMBIENTE PRODUZIONE (quando disponibile) ===
# Credenziali per ambiente di esercizio
VITE_RVFU_PRODUCTION_USERNAME=your_production_username
VITE_RVFU_PRODUCTION_PASSWORD=your_production_password

# Client ID e Secret per produzione
VITE_RVFU_CLIENT_ID_PROD=your_prod_client_id
VITE_RVFU_CLIENT_SECRET_PROD=your_prod_client_secret
VITE_RVFU_REDIRECT_URI_PROD=https://yourdomain.com/auth/callback

# === CONFIGURAZIONI AVANZATE ===
# Timeout per chiamate API (millisecondi)
VITE_RVFU_API_TIMEOUT=30000

# Retry automatico per chiamate fallite
VITE_RVFU_MAX_RETRIES=3

# Abilita logging dettagliato per debug
VITE_RVFU_DEBUG=true

# === INTEGRAZIONE MOBILE ===
# URL per deep linking da mobile
VITE_RVFU_MOBILE_DEEP_LINK=rescuemanager://auth/callback

# === FIRMA DIGITALE ===
# Configurazione per integrazione tablet/FDR
VITE_RVFU_FDR_ENABLED=true
VITE_RVFU_FDR_SERVICE_URL=https://fdr.serviziaci.it

# === MONITORAGGIO ===
# Abilita metriche e logging per monitoraggio
VITE_RVFU_METRICS_ENABLED=true
VITE_RVFU_LOG_LEVEL=info

# === PROXY SERVER ===
# Usa il proxy server VPS per gestire CDSSO automaticamente
# Quando abilitato, tutte le chiamate API passano attraverso il proxy
VITE_RVFU_USE_PROXY=true
VITE_RVFU_PROXY_URL=https://rvfu.rescuemanager.eu

# === RENTRI API ===
# URL del server VPS per le API RENTRI
# Se non configurato, usa automaticamente VITE_API_URL o fallback a Vercel
VITE_RENTRI_API_URL=https://rentri-test.rescuemanager.eu/api/rentri

# === SDI-SFTP API ===
# URL del server VPS per le API SDI-SFTP
# Usato per invio fatture via SFTP e gestione file ricevuti (FO, EO, ER)
VITE_SDI_SFTP_SERVER_URL=http://sdi-sftp.rescuemanager.eu

# === GOOGLE MAPS PLATFORM ===
# API Key per Google Maps Platform (Places API, Geocoding API)
# Ottieni la chiave da: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY=AIzaSyCQTOmuGfjh18o3OsGR9QRdx79MSdjHjWU

# === AGENZIA DELLE ENTRATE API ===
# API GRATUITA per verifica P.IVA e Codice Fiscale
# Registrazione: https://www.agenziaentrate.gov.it/portale/web/guest/servizi/api-management
# Dopo la registrazione, ottieni Client ID e Client Secret dall'area riservata
VITE_AGENZIA_ENTRATE_API_URL=https://api.agenziaentrate.gov.it
VITE_AGENZIA_ENTRATE_OAUTH_URL=https://api.agenziaentrate.gov.it/oauth
VITE_AGENZIA_ENTRATE_CLIENT_ID=your_client_id_here
VITE_AGENZIA_ENTRATE_CLIENT_SECRET=your_client_secret_here
