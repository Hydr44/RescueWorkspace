# RescueManager - Staging Environment Variables
# Copy this file to .env.staging and fill in your staging values

# Environment
NODE_ENV=staging
NEXT_PUBLIC_ENV=staging

# Supabase Staging
NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-staging-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key

# JWT Staging
JWT_SECRET=your-staging-jwt-secret-min-32-chars

# Upstash Redis Staging
UPSTASH_REDIS_REST_URL=https://your-staging-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-staging-redis-token

# Cloudflare R2 Staging
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-staging-access-key
R2_SECRET_ACCESS_KEY=your-staging-secret-key
R2_BUCKET_NAME=rescuemanager-staging

# Stripe Test Mode
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_test_...

# Email Staging
EMAIL_FROM=staging@rescuemanager.eu
EMAIL_API_KEY=your-staging-email-api-key

# VPS Services Staging
VPS_API_BASE_URL=https://staging-api.rescuemanager.eu
VPS_ASSIST_BASE=staging-assist.rescuemanager.eu
VPS_RENTRI_BASE=staging-rentri.rescuemanager.eu

# SDI Staging (same as prod)
SDI_ID_NODO=02166430856
SDI_ID_NODO_CF=SCZMNL05L21D960T

# Sentry Staging
NEXT_PUBLIC_SENTRY_DSN=your-staging-sentry-dsn
SENTRY_AUTH_TOKEN=your-sentry-token
SENTRY_ENVIRONMENT=staging
